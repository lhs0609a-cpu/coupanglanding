{
  "compilerOptions": {
    "noEmit": false,
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "outDir": "./.build-test",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": false,
    "incremental": false,
    "composite": false,
    "isolatedModules": false,
    "strict": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ES2020", "dom"]
  },
  "include": [
    "src/lib/megaload/services/persuasion-engine.ts",
    "src/lib/megaload/services/fragment-composer.ts",
    "src/lib/megaload/services/product-name-parser.ts",
    "src/lib/megaload/services/seo-keyword-resolver.ts",
    "src/lib/megaload/services/seeded-random.ts",
    "src/lib/megaload/services/health-sanitizer.ts",
    "src/lib/megaload/services/detail-page-builder.ts",
    "src/lib/megaload/services/option-extractor-test-shim.ts",
    "src/lib/megaload/data/**/*.json"
  ],
  "exclude": ["node_modules", "coupang-proxy"]
}
