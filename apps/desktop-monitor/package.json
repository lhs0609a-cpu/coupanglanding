{
  "name": "megaload-desktop-monitor",
  "version": "0.1.3",
  "description": "Megaload 상품 모니터링 도우미 — 등록 상품의 품절·가격 변동 자동 확인",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc -p tsconfig.json && npm run copy:assets && electron . --dev",
    "build": "tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "node -e \"require('fs').mkdirSync('dist/renderer',{recursive:true});require('fs').copyFileSync('src/renderer/index.html','dist/renderer/index.html')\"",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "build:all": "npm run build && electron-builder -mwl",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "electron",
    "megaload",
    "naver",
    "stock-monitor"
  ],
  "author": "Megaload",
  "license": "UNLICENSED",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "auto-launch": "^5.0.6",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/auto-launch": "^5.0.5",
    "@types/node": "^22.0.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.0"
  }
}
